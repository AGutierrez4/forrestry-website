---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar'
import Footer from '../../components/Footer'
import BlogLeadForm from '../../components/BlogLeadForm'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
})

const isoDate = post.data.publishDate.toISOString().split('T')[0]
const readingTime = Math.ceil(post.body.split(/\s+/).length / 230)

// Article Schema
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Forrestry.ai"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Forrestry.ai"
  },
  "datePublished": isoDate,
  "description": post.data.description,
  "image": post.data.heroImage ? {
    "@type": "ImageObject",
    "url": `https://www.forrestry.ai${post.data.heroImage}`,
    "width": 1200,
    "height": 630
  } : undefined,
  "wordCount": post.body.split(/\s+/).length,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.forrestry.ai/learning-center/${post.id}`
  }
})

// FAQ Schema (only if post has faq data)
const faqSchema = post.data.faq ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": post.data.faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
}) : null

// BreadcrumbList Schema
const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://www.forrestry.ai/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Learning Center",
      "item": "https://www.forrestry.ai/learning-center/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title
    }
  ]
})
---

<BaseLayout title={`${post.data.title} | Learning Center`} description={post.data.description} ogImage={post.data.heroImage}>
  <script type="application/ld+json" set:html={articleSchema} slot="head" />
  {faqSchema && <script type="application/ld+json" set:html={faqSchema} slot="head" />}
  <script type="application/ld+json" set:html={breadcrumbSchema} slot="head" />
  <Navbar client:load links={[{label:'Product',href:'/#studio'},{label:'Learning Center',href:'/learning-center'},{label:'Pricing',href:'/pricing'},{label:'About',href:'/about'}]} ctaText="Claim Founders Spot" ctaHref="https://buy.stripe.com/8x24gAcdt2nN2nOdi6frW01" signInHref="https://app.funnelstudio.forrestry.ai" logoHref="/" />

  <article class="pt-28 pb-24">
    <!-- Breadcrumb -->
    <div class="max-w-[800px] mx-auto px-6 mb-8">
      <nav>
        <a href="/learning-center" class="text-green text-sm font-medium no-underline hover:underline inline-flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Learning Center
        </a>
      </nav>
    </div>

    <!-- Hero Section -->
    <header class="max-w-[800px] mx-auto px-6 mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-green/10 text-green text-xs font-semibold tracking-wide uppercase">{post.data.category}</span>
        <span class="text-muted/60 text-xs">·</span>
        <span class="text-muted/60 text-xs">{readingTime} min read</span>
      </div>
      <h1 class="text-[clamp(1.75rem,4.5vw,2.75rem)] font-extrabold leading-[1.15] mb-6">{post.data.title}</h1>
      <p class="text-muted text-lg leading-relaxed mb-6">{post.data.description}</p>
      <div class="flex items-center gap-3 text-sm">
        <div class="w-8 h-8 rounded-full bg-green/20 flex items-center justify-center">
          <span class="text-green font-bold text-xs">AG</span>
        </div>
        <div class="flex flex-col">
          <span class="text-white font-medium text-sm">{post.data.author}</span>
          <time datetime={post.data.publishDate.toISOString()} class="text-muted/60 text-xs">{formattedDate}</time>
        </div>
      </div>
    </header>

    <!-- Hero Image -->
    {post.data.heroImage && (
      <div class="max-w-[900px] mx-auto px-6 mb-14">
        <div class="rounded-2xl overflow-hidden border border-white/[0.06]">
          <img
            src={post.data.heroImage}
            alt={post.data.title}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      </div>
    )}

    <!-- Article Body -->
    <div class="max-w-[800px] mx-auto px-6">
      <div class="bg-[#111111] border border-[#1f1f1f] rounded-2xl p-8 md:p-12 shadow-[0_0_80px_rgba(0,0,0,0.4)]">
        <div class="article-content">
          <Content />
        </div>

        <!-- Lead Magnet Form (inside the content card) -->
        {post.data.leadMagnet && (
          <div class="mt-14">
            <BlogLeadForm
              client:visible
              title={post.data.leadMagnet.title}
              description={post.data.leadMagnet.description}
              buttonText={post.data.leadMagnet.buttonText}
              downloadUrl={post.data.leadMagnet.downloadUrl}
            />
          </div>
        )}
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="max-w-[800px] mx-auto px-6 mt-20">
      <div class="relative rounded-2xl bg-gradient-to-br from-[#059669] via-[#047857] to-[#065F46] p-10 sm:p-16 text-center overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(255,255,255,0.1),_transparent_60%)]"></div>
        <div class="relative z-10">
          <h3 class="text-2xl font-bold text-white mb-3">Ready to launch your funnel?</h3>
          <p class="text-white/80 text-base mb-8 max-w-md mx-auto leading-relaxed">Funnel Studio turns one conversation into a complete funnel ecosystem. Strategy, copy, emails, ads, all from one Brain Dump.</p>
          <a href="https://buy.stripe.com/8x24gAcdt2nN2nOdi6frW01" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-white text-[#047857] font-bold text-base no-underline shadow-lg hover:bg-white/90 hover:scale-[1.02] transition-all">
            Get Access to Funnel Studio — $97
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </article>

  <Footer links={[{label:'Product',href:'/#studio'},{label:'Learning Center',href:'/learning-center'},{label:'Pricing',href:'/pricing'},{label:'About',href:'/about'},{label:'Privacy',href:'/privacy'},{label:'Terms',href:'/terms'}]} tagline="Stop Building. Start Launching." />
</BaseLayout>
