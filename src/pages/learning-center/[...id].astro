---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Navbar from '../../components/Navbar'
import Footer from '../../components/Footer'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)

const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
})

const isoDate = post.data.publishDate.toISOString().split('T')[0]

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Forrestry.ai"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Forrestry.ai"
  },
  "datePublished": isoDate,
  "description": post.data.description,
  "mainEntityOfPage": {
    "@type": "WebPage"
  }
})
---

<BaseLayout title={`${post.data.title} | Learning Center`} description={post.data.description}>
  <script type="application/ld+json" set:html={articleSchema} slot="head" />
  <Navbar client:load links={[{label:'Product',href:'/#studio'},{label:'Learning Center',href:'/learning-center'},{label:'Pricing',href:'/pricing'},{label:'About',href:'/about'}]} ctaText="Claim Founders Spot" ctaHref="https://buy.stripe.com/8x24gAcdt2nN2nOdi6frW01" signInHref="https://app.funnelstudio.forrestry.ai" logoHref="/" />

  <article class="pt-32 pb-24 px-6">
    <div class="max-w-[720px] mx-auto">
      <nav class="mb-8">
        <a href="/learning-center" class="text-green text-sm font-medium no-underline hover:underline">← Learning Center</a>
      </nav>
      <header class="mb-12">
        <span class="text-green text-xs font-semibold tracking-wide uppercase">{post.data.category}</span>
        <h1 class="text-[clamp(2rem,5vw,3rem)] font-extrabold leading-[1.15] mt-2 mb-4">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-muted text-sm">
          <span>{post.data.author}</span>
          <span>·</span>
          <time datetime={post.data.publishDate.toISOString()}>{formattedDate}</time>
        </div>
      </header>
      <div class="prose prose-invert prose-green max-w-none prose-headings:font-bold prose-headings:text-white prose-p:text-white/70 prose-p:leading-relaxed prose-a:text-green prose-a:no-underline prose-strong:text-white prose-li:text-white/70">
        <Content />
      </div>
      <div class="mt-16 p-8 rounded-2xl bg-white/[0.03] border border-white/[0.06] text-center">
        <h3 class="text-xl font-bold text-white mb-3">Ready to launch your funnel?</h3>
        <p class="text-muted text-sm mb-6 max-w-md mx-auto">Funnel Studio turns one conversation into a complete funnel ecosystem.</p>
        <a href="https://buy.stripe.com/8x24gAcdt2nN2nOdi6frW01" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-3 rounded-xl bg-green text-black font-bold text-sm no-underline shadow-[0_0_30px_rgba(74,222,128,0.15)] hover:bg-green/90 transition-all">Claim Your Founders Spot. $47/mo</a>
      </div>
    </div>
  </article>

  <Footer links={[{label:'Product',href:'/#studio'},{label:'Learning Center',href:'/learning-center'},{label:'Pricing',href:'/pricing'},{label:'About',href:'/about'},{label:'Privacy',href:'/privacy'},{label:'Terms',href:'/terms'}]} tagline="Stop Building. Start Launching." />
</BaseLayout>
