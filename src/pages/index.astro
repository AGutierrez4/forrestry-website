---
import BaseLayout from '../layouts/BaseLayout.astro'
import Navbar from '../components/Navbar'
import CompanyHero from '../components/company/CompanyHero'
import StudioBento from '../components/company/StudioBento'
import EfficiencyTable from '../components/company/EfficiencyTable'
import Benefits from '../components/company/Benefits'
import Problem from '../components/company/Problem'
import Founder from '../components/company/Founder'
import Objections from '../components/company/Objections'
import FoundersPricing from '../components/company/FoundersPricing'
import CompanyCTA from '../components/company/CompanyCTA'
import Footer from '../components/Footer'
---

<BaseLayout title="forrestry.ai | Turn One Conversation Into a Complete Funnel" description="You learned the strategy. Now launch the funnel. One guided conversation turns your idea into a complete, connected funnel ecosystem.">
  <Navbar client:load links={[{label:'Product',href:'/#studio'},{label:'Pricing',href:'/pricing'},{label:'About',href:'/about'}]} ctaText="Claim Founders Spot" ctaHref="https://buy.stripe.com/8x24gAcdt2nN2nOdi6frW01" signInHref="https://app.funnelstudio.forrestry.ai" logoHref="/" />
  <main>
    <CompanyHero client:load />
    <StudioBento client:visible />
    <EfficiencyTable client:visible />
    <Problem client:visible />
    <Benefits client:visible />
    <Founder client:visible />
    <Objections client:visible />
    <FoundersPricing client:visible />
    <CompanyCTA client:visible />
  </main>
  <Footer links={[{label:'Product',href:'/#studio'},{label:'Pricing',href:'/pricing'},{label:'About',href:'/about'},{label:'Privacy',href:'/privacy'},{label:'Terms',href:'/terms'}]} tagline="Stop Building. Start Launching." />
</BaseLayout>
